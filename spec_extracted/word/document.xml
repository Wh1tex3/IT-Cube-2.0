crosoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 w15 w16se w16cid wp14"><w:body><w:p w14:paraId="6D274930" w14:textId="77777777" w:rsidR="00662FCA" w:rsidRDefault="00662FCA"><w:r><w:t>Для удобства работы над проектом при имеющемся потоке информации весь функционал разделен на:</w:t></w:r></w:p><w:p w14:paraId="0468568D" w14:textId="4F540789" w:rsidR="00662FCA" w:rsidRDefault="00662FCA"><w:r><w:t>1. Первостепенны</w:t></w:r><w:r w:rsidR="00F7780C"><w:t>й</w:t></w:r><w:r><w:t xml:space="preserve"> – простой текст</w:t></w:r></w:p><w:p w14:paraId="0E229BBE" w14:textId="59FD17F3" w:rsidR="00662FCA" w:rsidRDefault="00662FCA"><w:r><w:t xml:space="preserve">2. Желательный, необходимый – текст, </w:t></w:r><w:r w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t>залитый голубым</w:t></w:r></w:p><w:p w14:paraId="1EAF0E75" w14:textId="538501B0" w:rsidR="00662FCA" w:rsidRDefault="00662FCA"><w:r><w:t xml:space="preserve">3. Реализуемый в далёком будущем, при условии создания функционала 1 и 2 пунктов – </w:t></w:r><w:r w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="magenta"/></w:rPr><w:t>пурпурный цвет</w:t></w:r><w:r><w:t xml:space="preserve">.  </w:t></w:r></w:p><w:p w14:paraId="767967E5" w14:textId="565F3CDF" w:rsidR="00A241F8" w:rsidRDefault="00942F57"><w:r><w:t xml:space="preserve">Планируется разработка образовательной платформы с элементами геймификации по обучению </w:t></w:r><w:r w:rsidR="00710347"><w:t xml:space="preserve">детей </w:t></w:r><w:r><w:t>робототехнике</w:t></w:r><w:r w:rsidR="00710347"><w:t>.</w:t></w:r></w:p><w:p w14:paraId="485E3D3E" w14:textId="62604113" w:rsidR="006B4043" w:rsidRDefault="00710347"><w:r><w:t xml:space="preserve">Целевая аудитория: дети 5-10 лет, педагоги дополнительного образования. </w:t></w:r></w:p><w:p w14:paraId="575A3646" w14:textId="77777777" w:rsidR="00942F57" w:rsidRDefault="00942F57" w:rsidP="00942F57"><w:r><w:t xml:space="preserve">Основные разделы: </w:t></w:r></w:p><w:p w14:paraId="63E34197" w14:textId="6FD6AAB8" w:rsidR="00942F57" w:rsidRDefault="00942F57" w:rsidP="00942F57"><w:r><w:t>1) Инструкции</w:t></w:r></w:p><w:p w14:paraId="271A0578" w14:textId="071C2989" w:rsidR="00942F57" w:rsidRPr="00662FCA" w:rsidRDefault="00942F57" w:rsidP="00942F57"><w:pPr><w:rPr><w:highlight w:val="cyan"/></w:rPr></w:pPr><w:r w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t>2) Статистика</w:t></w:r></w:p><w:p w14:paraId="5E722BB5" w14:textId="33A531D6" w:rsidR="00710347" w:rsidRPr="00662FCA" w:rsidRDefault="00710347" w:rsidP="00942F57"><w:pPr><w:rPr><w:highlight w:val="cyan"/></w:rPr></w:pPr><w:r w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t xml:space="preserve">3) Авторизация / Регистрация </w:t></w:r></w:p><w:p w14:paraId="6375A1A7" w14:textId="71222250" w:rsidR="00F3029B" w:rsidRDefault="00F3029B" w:rsidP="00942F57"><w:r w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t>4) Панель администратора</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r></w:p><w:p w14:paraId="24A9EF31" w14:textId="77777777" w:rsidR="00F3029B" w:rsidRDefault="00F3029B" w:rsidP="00942F57"><w:r><w:t xml:space="preserve">Роли на сайте: </w:t></w:r></w:p><w:p w14:paraId="0B85CD39" w14:textId="61A040B4" w:rsidR="00F3029B" w:rsidRDefault="00F3029B" w:rsidP="00942F57"><w:r><w:t>- Пользователи – это учащиеся (получает доступ к материалам сайта)</w:t></w:r></w:p><w:p w14:paraId="243F40F2" w14:textId="7F59123A" w:rsidR="00F3029B" w:rsidRDefault="00F3029B" w:rsidP="00942F57"><w:r><w:t xml:space="preserve">- Администраторы – педагоги (добавляет материалы на сайт, пролонгирует регистрацию пользователей, </w:t></w:r><w:r w:rsidR="00C905AF"><w:t xml:space="preserve">удаляет пользователей своего образовательного пространства, </w:t></w:r><w:r><w:t>видит статистику и список пользователей своего образовательного пространства)</w:t></w:r><w:r w:rsidR="00C905AF"><w:t>.</w:t></w:r></w:p><w:p w14:paraId="099CD655" w14:textId="2265F32E" w:rsidR="00F3029B" w:rsidRPr="00F3029B" w:rsidRDefault="00F3029B" w:rsidP="00942F57"><w:r><w:t xml:space="preserve">- Модератор – создатель сайта (пролонгирует регистрацию </w:t></w:r><w:r w:rsidR="00C905AF"><w:t>администраторов, видит полную статистику и список пользователей, администраторов, удаляет пользователей и администраторов сайта).</w:t></w:r></w:p><w:p w14:paraId="69530D7B" w14:textId="12303E41" w:rsidR="00942F57" w:rsidRPr="00662FCA" w:rsidRDefault="00942F57"><w:pPr><w:rPr><w:highlight w:val="magenta"/></w:rPr></w:pPr><w:r w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="magenta"/></w:rPr><w:t>Дополнительные разделы (на будущую реализацию)</w:t></w:r><w:r w:rsidR="00F3029B" w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="magenta"/></w:rPr><w:t>:</w:t></w:r></w:p><w:p w14:paraId="07FC23B5" w14:textId="3B7F9277" w:rsidR="00942F57" w:rsidRPr="00662FCA" w:rsidRDefault="00942F57"><w:pPr><w:rPr><w:highlight w:val="magenta"/></w:rPr></w:pPr><w:r w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="magenta"/></w:rPr><w:t>1) Механика</w:t></w:r></w:p><w:p w14:paraId="3D7CDCC9" w14:textId="581CCDF5" w:rsidR="00942F57" w:rsidRPr="00662FCA" w:rsidRDefault="00942F57"><w:pPr><w:rPr><w:highlight w:val="magenta"/></w:rPr></w:pPr><w:r w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="magenta"/></w:rPr><w:t>2) Программирование</w:t></w:r></w:p><w:p w14:paraId="4F7B21BD" w14:textId="4D4FC500" w:rsidR="00942F57" w:rsidRDefault="00942F57"><w:r w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="magenta"/></w:rPr><w:t>3) Проекты</w:t></w:r></w:p><w:p w14:paraId="5619E3E0" w14:textId="77777777" w:rsidR="00F3029B" w:rsidRDefault="006414FE"><w:r><w:t>Описание страницы Инструкции:</w:t></w:r></w:p><w:p w14:paraId="53686547" w14:textId="7BB23FEB" w:rsidR="00F3029B" w:rsidRDefault="00F3029B"><w:r><w:t xml:space="preserve">Это главная страница сайта, после авторизации пользователь сразу попадает сюда. </w:t></w:r></w:p><w:p w14:paraId="07164953" w14:textId="01A3285C" w:rsidR="00AD3FE9" w:rsidRDefault="00A11E68"><w:r w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t>1.</w:t></w:r><w:r w:rsidR="00F3029B" w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t xml:space="preserve"> </w:t></w:r><w:r w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t>Н</w:t></w:r><w:r w:rsidR="00F3029B" w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t xml:space="preserve">евысокий раздел-баннер с отображением: Название объединения, </w:t></w:r><w:r w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t>ФИО педагога, Статистика пользователя, например «Инструкции</w:t></w:r><w:r w:rsidR="00662FCA" w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t>:</w:t></w:r><w:r w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t xml:space="preserve"> 3/100»</w:t></w:r><w:r w:rsidR="002A3D67" w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t>,</w:t></w:r><w:r w:rsidR="00662FCA" w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t xml:space="preserve"> </w:t></w:r><w:r w:rsidR="002A3D67" w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t>«О</w:t></w:r><w:r w:rsidR="00662FCA" w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t>пыт: 1500</w:t></w:r><w:r w:rsidR="002A3D67" w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t>»</w:t></w:r><w:r w:rsidR="006414FE"><w:br/></w:r><w:r><w:t>2. Р</w:t></w:r><w:r w:rsidR="006414FE"><w:t xml:space="preserve">аздел со списком робототехнических инструкций, далее – Инструкции. Визуально </w:t></w:r><w:r w:rsidR="00AD3FE9"><w:t xml:space="preserve">каждая Инструкция в списке — это отдельный блок, содержащий: Изображение собираемого объекта, Название, Категория, </w:t></w:r><w:r w:rsidR="008F303D"><w:t xml:space="preserve">Макс. Количество опыта (возможного за получение при сборке инструкции) в формате </w:t></w:r><w:r w:rsidR="008F303D" w:rsidRPr="008F303D"><w:t>[</w:t></w:r><w:r w:rsidR="008F303D"><w:t>иконка-</w:t></w:r><w:proofErr w:type="gramStart"/><w:r w:rsidR="008F303D"><w:t>звёздочка</w:t></w:r><w:r w:rsidR="008F303D" w:rsidRPr="008F303D"><w:t>][</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r w:rsidR="003A3CD3"><w:t xml:space="preserve">макс. </w:t></w:r><w:r w:rsidR="008F303D"><w:t>число</w:t></w:r><w:r w:rsidR="008F303D" w:rsidRPr="008F303D"><w:t>]</w:t></w:r><w:r w:rsidR="008F303D"><w:t xml:space="preserve">, </w:t></w:r><w:r w:rsidR="00AD3FE9"><w:t>Ссылка</w:t></w:r><w:r w:rsidR="00AD3FE9" w:rsidRPr="00AD3FE9"><w:t>/</w:t></w:r><w:r w:rsidR="00AD3FE9"><w:t>Кнопка «Открыть инструкцию»</w:t></w:r><w:r w:rsidR="006414FE"><w:t xml:space="preserve"> </w:t></w:r><w:r w:rsidR="00AD3FE9"><w:t xml:space="preserve">для перехода на отдельную страницу Инструкции. </w:t></w:r></w:p><w:p w14:paraId="75DF12B4" w14:textId="40BE8E49" w:rsidR="00A11E68" w:rsidRDefault="00A11E68"><w:r w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t>2.1. Изображение, Название, Категория – указываются (вводятся) администратором вручную при создании отдельной Инструкции.</w:t></w:r></w:p><w:p w14:paraId="69656B98" w14:textId="7C003458" w:rsidR="00A11E68" w:rsidRDefault="00A11E68"><w:r w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:lastRenderedPageBreak/><w:t xml:space="preserve">2.2. Макс. </w:t></w:r><w:r w:rsidR="002A3D67" w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t>ч</w:t></w:r><w:r w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t xml:space="preserve">исло опыта </w:t></w:r><w:r w:rsidR="002A3D67" w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t xml:space="preserve">по каждой Инструкции </w:t></w:r><w:r w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t>высчитывается автоматически на основе суммарных показателей указываемых администратором: количество слайдов, количество сложных соединений, программируемая сложност</w:t></w:r><w:r w:rsidR="002A3D67" w:rsidRPr="00662FCA"><w:rPr><w:highlight w:val="cyan"/></w:rPr><w:t>ь (список от 1 до 5, где 1 – легко, 5 очень сложно), +10% за самостоятельную сборку (без участия педагога и без значительных ошибок), +10% за самостоятельное программирование робота (без участия педагога и без значительных ошибок), +10% за устранение неисправности (либо возникшей при сборке по вине учащегося, либо педагог намеренно убирает деталь / усложняет сборку / задаёт уточняющий вопрос).</w:t></w:r><w:r w:rsidR="002A3D67" w:rsidRPr="002A3D67"><w:t xml:space="preserve"> </w:t></w:r></w:p><w:p w14:paraId="786D3A85" w14:textId="07C2842C" w:rsidR="00AD3FE9" w:rsidRDefault="006414FE" w:rsidP="00F3029B"><w:r><w:t>- выбор (фильтр, сортировка) Инструкций по категориям, дале - Категории: транспорт, животные, космос, тематические... (инструкции могут принадлежать сразу к нескольким категориям).</w:t></w:r></w:p><w:p w14:paraId="1001E6B1" w14:textId="186D0022" w:rsidR="00AD3FE9" w:rsidRDefault="006414FE" w:rsidP="00F3029B"><w:r><w:t>- выбор (фильтр, сортировка) по сложности, далее – Сложность: легко, средне, продвинуто</w:t></w:r></w:p><w:p w14:paraId="3BE70197" w14:textId="10014B68" w:rsidR="006414FE" w:rsidRDefault="006414FE" w:rsidP="00F3029B"><w:r><w:t>- раздел с коллекциями, далее - Коллекции (</w:t></w:r><w:r w:rsidR="00F3029B"><w:t>отдельный раздел,</w:t></w:r><w:r><w:t xml:space="preserve"> содержащий </w:t></w:r><w:r w:rsidR="00F3029B"><w:t>несколько Инструкций,</w:t></w:r><w:r><w:t xml:space="preserve"> принадлежащих единой Коллекции: </w:t></w:r><w:r><w:rPr><w:lang w:val="en-US"/></w:rPr><w:t>Mini</w:t></w:r><w:r w:rsidRPr="006414FE"><w:t>-</w:t></w:r><w:r><w:rPr><w:lang w:val="en-US"/></w:rPr><w:t>car</w:t></w:r><w:r w:rsidRPr="006414FE"><w:t xml:space="preserve">, </w:t></w:r><w:r><w:rPr><w:lang w:val="en-US"/></w:rPr><w:t>Zoo</w:t></w:r><w:r w:rsidRPr="006414FE"><w:t>-</w:t></w:r><w:r><w:rPr><w:lang w:val="en-US"/></w:rPr><w:t>car</w:t></w:r><w:r><w:t xml:space="preserve">, Хеллоуин, 23 Февраля и </w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:t>тд</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:t>.).</w:t></w:r></w:p><w:p w14:paraId="7DC0DFEA" w14:textId="7003558E" w:rsidR="00AD3FE9" w:rsidRDefault="00662FCA"><w:r><w:t>Элементы г</w:t></w:r><w:r w:rsidR="00AD3FE9"><w:t>еймификаци</w:t></w:r><w:r><w:t>и</w:t></w:r><w:r w:rsidR="00AD3FE9"><w:t>:</w:t></w:r></w:p><w:p w14:paraId="034971C2" w14:textId="3649F28E" w:rsidR="00AD3FE9" w:rsidRDefault="00AD3FE9"><w:r><w:t>1. Блоки инструкций изначально белые, но после прохождения (сборки) инструкции приобретают цвет сложности</w:t></w:r><w:r w:rsidR="008F303D"><w:t>, например</w:t></w:r><w:r><w:t xml:space="preserve">: </w:t></w:r><w:r w:rsidR="008F303D"><w:t xml:space="preserve">лесной </w:t></w:r><w:r><w:t>зел</w:t></w:r><w:r w:rsidR="008F303D"><w:t>ё</w:t></w:r><w:r><w:t>ный</w:t></w:r><w:r w:rsidR="008F303D"><w:t xml:space="preserve"> (легкий)</w:t></w:r><w:r><w:t xml:space="preserve">, </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidR="008F303D"><w:t>ш</w:t></w:r><w:r w:rsidR="008F303D" w:rsidRPr="008F303D"><w:t>афраново</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidR="008F303D" w:rsidRPr="008F303D"><w:t>-жёлтый</w:t></w:r><w:r w:rsidR="008F303D"><w:t xml:space="preserve"> (средний)</w:t></w:r><w:r><w:t xml:space="preserve">, </w:t></w:r><w:r w:rsidR="008F303D"><w:t>рубиново-красный (сложный). Таким способом происходит визуальное отделение завершенных (собранных) инструкций от тех которые пользователь ещё не собирал.</w:t></w:r></w:p><w:p w14:paraId="396FBAF0" w14:textId="21AD4FAB" w:rsidR="008F303D" w:rsidRDefault="008F303D"><w:r><w:t>2. До сборки отдельных инструкций звёздочки в блоках инструкций залиты в цвет сложности</w:t></w:r><w:r w:rsidR="003A3CD3"><w:t>, ровно также, как и число максимально опыта</w:t></w:r><w:r><w:t xml:space="preserve">. После сборки блок окрашивается в фон сложности, а звёздочка становится полностью белой. </w:t></w:r><w:r w:rsidR="003A3CD3"><w:t xml:space="preserve">Изначальный текст, например «Макс. 100», теперь отображает фактически полученный за сборку инструкции опыт «93». </w:t></w:r></w:p><w:p w14:paraId="10D61DD4" w14:textId="68797C2B" w:rsidR="006B4043" w:rsidRDefault="006B4043"><w:r><w:t>Стек технологий:</w:t></w:r></w:p><w:p w14:paraId="1B937A61" w14:textId="0F2185FA" w:rsidR="006B4043" w:rsidRDefault="006B4043" w:rsidP="006B4043"><w:r><w:t>HTML5 – структура страниц (обязателен).</w:t></w:r></w:p><w:p w14:paraId="140954DC" w14:textId="78958BF6" w:rsidR="006B4043" w:rsidRDefault="006B4043" w:rsidP="004C483C"><w:r><w:t xml:space="preserve">Bootstrap5 – готовая сетка, кнопки, карточки, </w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:t>адаптив</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:t xml:space="preserve"> под телефоны; сильно ускорит старт, особенно для карточек инструкций и коллекций</w:t></w:r><w:r w:rsidR="004C483C"><w:t xml:space="preserve"> (обязателен)</w:t></w:r><w:r><w:t>.</w:t></w:r></w:p><w:p w14:paraId="179D5A3C" w14:textId="01A409BA" w:rsidR="006B4043" w:rsidRDefault="006B4043" w:rsidP="006B4043"><w:proofErr w:type="spellStart"/><w:r><w:t>Vue</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:t xml:space="preserve"> 3 – основная «движущая сила» </w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:t>фронтенда</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:t>: фильтры, сортировки, смена цвета карточек после выполнения инструкции, работа со списками и статусом пользователя</w:t></w:r><w:r w:rsidR="004C483C"><w:t xml:space="preserve"> (обязателен)</w:t></w:r><w:r><w:t>.</w:t></w:r></w:p><w:p w14:paraId="4C8EC9D4" w14:textId="5F467378" w:rsidR="007900F1" w:rsidRDefault="007900F1" w:rsidP="004C483C"><w:r><w:t>Дополнительно (по требованию</w:t></w:r><w:r w:rsidRPr="004C483C"><w:t>/</w:t></w:r><w:r><w:t>желанию):</w:t></w:r></w:p><w:p w14:paraId="1C274E7C" w14:textId="6E0341E3" w:rsidR="004C483C" w:rsidRDefault="004C483C" w:rsidP="004C483C"><w:r><w:t>CSS3 – стили и оформление.</w:t></w:r><w:r w:rsidRPr="004C483C"><w:t xml:space="preserve"> </w:t></w:r></w:p><w:p w14:paraId="40BE6D96" w14:textId="197882F4" w:rsidR="004C483C" w:rsidRDefault="004C483C" w:rsidP="004C483C"><w:r><w:t>JavaScript (чистый) – базовое понимание: работа с DOM, события, простая логика</w:t></w:r><w:r w:rsidR="007900F1"><w:t xml:space="preserve">. </w:t></w:r></w:p><w:p w14:paraId="3F4486BC" w14:textId="0D6424BF" w:rsidR="001B6854" w:rsidRDefault="001B6854" w:rsidP="004C483C"><w:r><w:t>Дизайн:</w:t></w:r></w:p><w:p w14:paraId="55E272A0" w14:textId="705931C6" w:rsidR="001B6854" w:rsidRPr="001B6854" w:rsidRDefault="001B6854" w:rsidP="004C483C"><w:r><w:t>Стильный, современный, лёгкий (вдохновиться идеями</w:t></w:r><w:bookmarkStart w:id="0" w:name="_GoBack"/><w:bookmarkEnd w:id="0"/><w:r><w:t xml:space="preserve"> с сайта </w:t></w:r><w:r><w:rPr><w:lang w:val="en-US"/></w:rPr><w:t>Bechance</w:t></w:r><w:r w:rsidRPr="001B6854"><w:t xml:space="preserve">). </w:t></w:r></w:p><w:p w14:paraId="52A93761" w14:textId="77777777" w:rsidR="004C483C" w:rsidRPr="006414FE" w:rsidRDefault="004C483C" w:rsidP="006B4043"/><w:sectPr w:rsidR="004C483C" w:rsidRPr="006414FE"><w:pgSz w:w="11906" w:h="16838"/><w:pgMar w:top="1134" w:right="850" w:bottom="1134" w:left="1701" w:header="708" w:footer="708" w:gutter="0"/><w:cols w:space="708"/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>